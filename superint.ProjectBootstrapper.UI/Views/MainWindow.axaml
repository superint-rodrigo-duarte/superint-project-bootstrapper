        <!-- Navigation Icons (Fluent UI System Icons) -->
        <StreamGeometry x:Key="IconDashboard">M10.5498 2.53583C11.3487 1.82138 12.5419 1.82138 13.3408 2.53583L20.5037 8.93983C21.1199 9.4906 21.4724 10.277 21.4724 11.1027V18.7494C21.4724 20.1301 20.3531 21.2494 18.9724 21.2494H14.9747C14.5605 21.2494 14.2247 20.9136 14.2247 20.4994V15.5044C14.2247 15.228 14.0008 15.0044 13.7243 15.0044H10.1661C9.88966 15.0044 9.66577 15.2283 9.66577 15.5047V20.4994C9.66577 20.9136 9.32999 21.2494 8.91577 21.2494H4.9181C3.5374 21.2494 2.4181 20.1301 2.4181 18.7494V11.1027C2.4181 10.277 2.77061 9.4906 3.38678 8.93983L10.5498 2.53583ZM12.3563 3.63683C12.0837 3.39312 11.6715 3.39312 11.3989 3.63683L4.23687 10.0408C3.92852 10.3165 3.75313 10.7097 3.75313 11.1227V18.7494C3.75313 19.3017 4.2008 19.7494 4.75313 19.7494H8.41577V15.5047C8.41577 14.5378 9.19936 13.7544 10.1661 13.7544H13.7243C14.6912 13.7544 15.4747 14.5375 15.4747 15.5044V19.7494H19.1374C19.6897 19.7494 20.1374 19.3017 20.1374 18.7494V11.1227C20.1374 10.7097 19.9621 10.3165 19.6537 10.0408L12.3563 3.63683Z</StreamGeometry>
        <StreamGeometry x:Key="IconSecrets">M12 2C14.2091 2 16 3.79086 16 6V8H17C18.1046 8 19 8.89543 19 10V20C19 21.1046 18.1046 22 17 22H7C5.89543 22 5 21.1046 5 20V10C5 8.89543 5.89543 8 7 8H8V6C8 3.79086 9.79086 2 12 2ZM17 9.5H7C6.72386 9.5 6.5 9.72386 6.5 10V20C6.5 20.2761 6.72386 20.5 7 20.5H17C17.2761 20.5 17.5 20.2761 17.5 20V10C17.5 9.72386 17.2761 9.5 17 9.5ZM12 13C12.8284 13 13.5 13.6716 13.5 14.5C13.5 15.0163 13.2438 15.4741 12.8535 15.7558L13 18H11L11.1465 15.7558C10.7562 15.4741 10.5 15.0163 10.5 14.5C10.5 13.6716 11.1716 13 12 13ZM12 3.5C10.6193 3.5 9.5 4.61929 9.5 6V8H14.5V6C14.5 4.61929 13.3807 3.5 12 3.5Z</StreamGeometry>
        <StreamGeometry x:Key="IconConnections">M12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2ZM12 3.5C7.30558 3.5 3.5 7.30558 3.5 12C3.5 16.6944 7.30558 20.5 12 20.5C16.6944 20.5 20.5 16.6944 20.5 12C20.5 7.30558 16.6944 3.5 12 3.5ZM10.75 13.4393L15.2197 8.96967C15.5126 8.67678 15.9874 8.67678 16.2803 8.96967C16.5466 9.23594 16.5708 9.6526 16.3529 9.94621L16.2803 10.0303L11.2803 15.0303C11.0141 15.2966 10.5974 15.3208 10.3038 15.1029L10.2197 15.0303L7.71967 12.5303C7.42678 12.2374 7.42678 11.7626 7.71967 11.4697C7.98594 11.2034 8.4026 11.1792 8.69621 11.3971L8.78033 11.4697L10.75 13.4393L15.2197 8.96967L10.75 13.4393Z</StreamGeometry>
        <StreamGeometry x:Key="IconBootstrap">M17.75 3C19.5449 3 21 4.45507 21 6.25V17.75C21 19.5449 19.5449 21 17.75 21H6.25C4.45507 21 3 19.5449 3 17.75V6.25C3 4.45507 4.45507 3 6.25 3H17.75ZM17.75 4.5H6.25C5.2835 4.5 4.5 5.2835 4.5 6.25V17.75C4.5 18.7165 5.2835 19.5 6.25 19.5H17.75C18.7165 19.5 19.5 18.7165 19.5 17.75V6.25C19.5 5.2835 18.7165 4.5 17.75 4.5ZM12 7C12.4142 7 12.75 7.33579 12.75 7.75V11.25H16.25C16.6642 11.25 17 11.5858 17 12C17 12.4142 16.6642 12.75 16.25 12.75H12.75V16.25C12.75 16.6642 12.4142 17 12 17C11.5858 17 11.25 16.6642 11.25 16.25V12.75H7.75C7.33579 12.75 7 12.4142 7 12C7 11.5858 7.33579 11.25 7.75 11.25H11.25V7.75C11.25 7.33579 11.5858 7 12 7Z</StreamGeometry>
    </Window.Resources>

    <Grid ColumnDefinitions="75,*">
        <!-- NavBar -->
        <Border Grid.Column="0"
                Background="{DynamicResource Layer1BackgroundBrush}"
                CornerRadius="0,16,16,0"
                Margin="0,8,0,8">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Logo -->
                <PathIcon Grid.Row="0"
                          Data="{StaticResource IconLogo}"
                          Width="32"
                          Height="32"
                          Foreground="{DynamicResource SystemAccentBrush}"
                          HorizontalAlignment="Center"
                          Margin="0,16,0,16"/>

                <!-- Navigation Items -->
                <StackPanel Grid.Row="1" Spacing="4" Margin="4,0">
                    <!-- System Sections -->
                    <Button Classes="navItem"
                            Classes.selected="{Binding SelectedSectionKey, Converter={x:Static local:EqualityConverters.IsEqual}, ConverterParameter=dashboard}"
                            Command="{Binding NavigateToSectionCommand}"
                            CommandParameter="dashboard"
                            ToolTip.Tip="{x:Static strings:UIStrings+Sections.Dashboard}">
                        <PathIcon Data="{StaticResource IconDashboard}" Width="22" Height="22"/>
                    </Button>
                    <Button Classes="navItem"
                            Classes.selected="{Binding SelectedSectionKey, Converter={x:Static local:EqualityConverters.IsEqual}, ConverterParameter=secrets}"
                            Command="{Binding NavigateToSectionCommand}"
                            CommandParameter="secrets"
                            ToolTip.Tip="{x:Static strings:UIStrings+Sections.Secrets}">
                        <PathIcon Data="{StaticResource IconSecrets}" Width="22" Height="22"/>
                    </Button>
                    <Button Classes="navItem"
                            Classes.selected="{Binding SelectedSectionKey, Converter={x:Static local:EqualityConverters.IsEqual}, ConverterParameter=connections}"
                            Command="{Binding NavigateToSectionCommand}"
                            CommandParameter="connections"
                            ToolTip.Tip="{x:Static strings:UIStrings+Sections.TestConnections}">
                        <PathIcon Data="{StaticResource IconConnections}" Width="22" Height="22"/>
                    </Button>

                    <!-- Separator -->
                    <Border Height="1"
                            Background="{DynamicResource Layer2BackgroundBrush}"
                            Margin="8,8"/>

                    <!-- Modules -->
                    <Button Classes="navItem"
                            Classes.selected="{Binding SelectedSectionKey, Converter={x:Static local:EqualityConverters.IsEqual}, ConverterParameter=bootstrap}"
                            Command="{Binding NavigateToSectionCommand}"
                            CommandParameter="bootstrap"
                            ToolTip.Tip="{x:Static strings:UIStrings+Sections.BootstrapWizard}">
                        <PathIcon Data="{StaticResource IconBootstrap}" Width="22" Height="22"/>
                    </Button>
                </StackPanel>

                <!-- Empty bottom section (reserved for future actions) -->
                <StackPanel Grid.Row="2" Spacing="4" Margin="4,0,4,16">
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" RowDefinitions="*,Auto" Margin="8">
            <!-- Content Panel -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Layer1BackgroundBrush}"
                    CornerRadius="16"
                    Padding="24">
                <ScrollViewer>
                    <ContentControl Content="{Binding CurrentSectionView}"/>
                </ScrollViewer>
            </Border>

            <!-- Bottom Panel: Log -->
            <Border Grid.Row="1"
                    Background="{DynamicResource Layer2BackgroundBrush}"
                    CornerRadius="8"
                    Height="120"
                    Padding="12"
                    Margin="0,8,0,0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0"
                               Text="{x:Static strings:UIStrings+Sections.Log}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding LogMessages}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontFamily="Consolas, Courier New, monospace"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerTheme>
                            <ControlTheme TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                            </ControlTheme>
                        </ListBox.ItemContainerTheme>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
