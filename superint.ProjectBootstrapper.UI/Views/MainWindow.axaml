<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:superint.ProjectBootstrapper.UI.ViewModels"
        xmlns:local="using:superint.ProjectBootstrapper.UI.Converters"
        xmlns:strings="using:superint.ProjectBootstrapper.UI.Constants"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="superint.ProjectBootstrapper.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="superint.ai - Project Bootstrapper"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        Background="{DynamicResource RegionBrush}"
        WindowStartupLocation="CenterScreen">

