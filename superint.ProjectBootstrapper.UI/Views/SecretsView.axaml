<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:superint.ProjectBootstrapper.UI.ViewModels"
             xmlns:strings="using:superint.ProjectBootstrapper.UI.Constants"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="800"
             x:Class="superint.ProjectBootstrapper.UI.Views.SecretsView"
             x:DataType="vm:SecretsViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,12,24">
            <TextBlock Text="{x:Static strings:UIStrings+Sections.Secrets}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Content="{x:Static strings:UIStrings+Labels.Load}" Classes="function" Command="{Binding LoadSettingsCommand}"/>
                <Button Content="{x:Static strings:UIStrings+Labels.Save}" Classes="action" Command="{Binding SaveSettingsCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Settings Sections -->
        <ScrollViewer Grid.Row="1" Padding="0,0,12,0">
            <StackPanel Spacing="24">
                <!-- Git Section -->
                <Border Background="{DynamicResource Layer2BackgroundBrush}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Git (GitHub)" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextBrush}"/>

                        <Grid ColumnDefinitions="*,16,*" RowDefinitions="Auto,8,Auto">
                            <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.BaseUrl}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding GitBaseUrl}" Watermark="https://api.github.com"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Grid.Row="0" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.Provider}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding GitProvider}" Watermark="github"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="2" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.ApiToken}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding GitApiToken}" PasswordChar="•" Watermark="ghp_xxxxx"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Grid.Row="2" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.DefaultNamespace}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding GitDefaultNamespace}" Watermark="superint-ai"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Container Registry Section -->
                <Border Background="{DynamicResource Layer2BackgroundBrush}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Container Registry (Harbor)" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextBrush}"/>

                        <!-- Connection -->
                        <Grid ColumnDefinitions="*,16,*,16,*" RowDefinitions="Auto">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.Url}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding RegistryUrl}" Watermark="container-registry.example.com"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.Username}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding RegistryUsername}" Watermark="admin"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.Password}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding RegistryPassword}" PasswordChar="•"/>
                            </StackPanel>
                        </Grid>

                        <!-- Retention Policy -->
                        <TextBlock Text="{x:Static strings:UIStrings+Labels.RetentionPolicy}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0"/>
                        <Grid ColumnDefinitions="Auto,16,*,16,*,16,*,16,Auto" RowDefinitions="Auto">
                            <CheckBox Grid.Column="0" IsChecked="{Binding RetentionPolicyEnabled}" Content="{x:Static strings:UIStrings+Labels.Enabled}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.RetainCount}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding RetentionPolicyRetainCount}" Watermark="5"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.RepositoryPattern}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding RetentionPolicyRepositoryPattern}" Watermark="**"/>
                            </StackPanel>
                            <StackPanel Grid.Column="6" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.TagPattern}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding RetentionPolicyTagPattern}" Watermark="**"/>
                            </StackPanel>
                            <CheckBox Grid.Column="8" IsChecked="{Binding RetentionPolicyIncludeUntagged}" Content="{x:Static strings:UIStrings+Labels.IncludeUntagged}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Project Admin Users -->
                        <StackPanel Spacing="4" Margin="0,8,0,0">
                            <TextBlock Text="{x:Static strings:UIStrings+Labels.ProjectAdminUsers}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBox Text="{Binding ProjectAdminUsers}" Watermark="user1, user2, user3"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Jenkins Section -->
                <Border Background="{DynamicResource Layer2BackgroundBrush}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{x:Static strings:UIStrings+Services.Jenkins}" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextBrush}"/>

                        <!-- Connection -->
                        <Grid ColumnDefinitions="*,16,*,16,*,16,*" RowDefinitions="Auto">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.BaseUrl}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding JenkinsBaseUrl}" Watermark="https://cicd.example.com"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.Username}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding JenkinsUsername}" Watermark="admin"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.ApiToken}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding JenkinsApiToken}" PasswordChar="•"/>
                            </StackPanel>
                            <StackPanel Grid.Column="6" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.DefaultFolder}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding JenkinsDefaultFolder}" Watermark="(optional)"/>
                            </StackPanel>
                        </Grid>

                        <!-- Pipeline Settings -->
                        <TextBlock Text="Pipeline Settings" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0"/>
                        <Grid ColumnDefinitions="*,16,*,16,*" RowDefinitions="Auto">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.MaxBuildsToKeep}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding JenkinsMaxBuildsToKeep}" Watermark="5"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.Environments}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding JenkinsEnvironments}" Watermark="staging, main"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.CredentialsId}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding JenkinsCredentialsId}" Watermark="gitlab-credentials"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Servers Section -->
                <Border Background="{DynamicResource Layer2BackgroundBrush}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Servers (SSH)" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextBrush}"/>

                        <!-- STG -->
                        <StackPanel Spacing="8">
                            <Border Background="#3B82F6" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                <TextBlock Text="{x:Static strings:UIStrings+Environments.Staging}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                            <Grid ColumnDefinitions="2*,16,*,16,*,16,*">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{x:Static strings:UIStrings+Labels.Host}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding ServerStgHost}" Watermark="192.168.x.x"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="{x:Static strings:UIStrings+Labels.Port}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding ServerStgPort}" Watermark="22"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4" Spacing="4">
                                    <TextBlock Text="{x:Static strings:UIStrings+Labels.Username}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding ServerStgUsername}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="6" Spacing="4">
                                    <TextBlock Text="{x:Static strings:UIStrings+Labels.Password}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding ServerStgPassword}" PasswordChar="•"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- PRD -->
                        <StackPanel Spacing="8" Margin="0,8,0,0">
                            <Border Background="#EF4444" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                <TextBlock Text="{x:Static strings:UIStrings+Environments.Production}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                            <Grid ColumnDefinitions="2*,16,*,16,*,16,*">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{x:Static strings:UIStrings+Labels.Host}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding ServerPrdHost}" Watermark="xxx.xxx.xxx.xxx"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="{x:Static strings:UIStrings+Labels.Port}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding ServerPrdPort}" Watermark="22"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4" Spacing="4">
                                    <TextBlock Text="{x:Static strings:UIStrings+Labels.Username}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding ServerPrdUsername}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="6" Spacing="4">
                                    <TextBlock Text="{x:Static strings:UIStrings+Labels.Password}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding ServerPrdPassword}" PasswordChar="•"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- PostgreSQL Section -->
                <Border Background="{DynamicResource Layer2BackgroundBrush}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="PostgreSQL Container" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextBrush}"/>

                        <!-- STG -->
                        <StackPanel Spacing="8">
                            <Border Background="#3B82F6" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                <TextBlock Text="{x:Static strings:UIStrings+Environments.Staging}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                            <Grid ColumnDefinitions="*,16,*,16,*">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{x:Static strings:UIStrings+Labels.ContainerName}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding PostgresStgContainerName}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="{x:Static strings:UIStrings+Labels.AdminUser}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding PostgresStgAdminUser}" Watermark="postgres"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4" Spacing="4">
                                    <TextBlock Text="{x:Static strings:UIStrings+Labels.AdminPassword}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding PostgresStgAdminPassword}" PasswordChar="•"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- PRD -->
                        <StackPanel Spacing="8" Margin="0,8,0,0">
                            <Border Background="#EF4444" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                <TextBlock Text="{x:Static strings:UIStrings+Environments.Production}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                            <Grid ColumnDefinitions="*,16,*,16,*">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{x:Static strings:UIStrings+Labels.ContainerName}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding PostgresPrdContainerName}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="{x:Static strings:UIStrings+Labels.AdminUser}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding PostgresPrdAdminUser}" Watermark="postgres"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4" Spacing="4">
                                    <TextBlock Text="{x:Static strings:UIStrings+Labels.AdminPassword}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding PostgresPrdAdminPassword}" PasswordChar="•"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Deployment Section -->
                <Border Background="{DynamicResource Layer2BackgroundBrush}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Deployment" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextBrush}"/>

                        <Grid ColumnDefinitions="*,16,*" RowDefinitions="Auto,8,Auto">
                            <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.BasePath}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding DeploymentBasePath}" Watermark="/opt/project-data"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Grid.Row="0" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.NetworkName}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding DeploymentNetworkName}" Watermark="superint-network"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="2" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.ReverseProxyHostStaging}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding DeploymentReverseProxyHostStaging}" Watermark="systems-stg.example.com"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Grid.Row="2" Spacing="4">
                                <TextBlock Text="{x:Static strings:UIStrings+Labels.ReverseProxyHostProduction}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox Text="{Binding DeploymentReverseProxyHostProduction}" Watermark="systems.example.com"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
