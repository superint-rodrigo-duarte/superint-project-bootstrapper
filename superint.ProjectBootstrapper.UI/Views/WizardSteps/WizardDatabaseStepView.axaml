<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:superint.ProjectBootstrapper.UI.ViewModels.WizardSteps"
             xmlns:strings="using:superint.ProjectBootstrapper.UI.Constants"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
             x:Class="superint.ProjectBootstrapper.UI.Views.WizardSteps.WizardDatabaseStepView"
             x:DataType="vm:WizardDatabaseStepViewModel">

    <StackPanel Spacing="16">
        <!-- Header with Toggle -->
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Database (PostgreSQL)"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}"/>
            <ToggleSwitch Grid.Column="1"
                          IsChecked="{Binding IsEnabled}"
                          OnContent="{x:Static strings:UIStrings+Labels.Create}"
                          OffContent="{x:Static strings:UIStrings+Labels.Skip}"/>
        </Grid>

        <!-- Form Fields -->
        <StackPanel Spacing="16" IsEnabled="{Binding IsEnabled}">
            <!-- STG Section -->
            <Border Background="{DynamicResource Layer1BackgroundBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="Auto,*">
                        <CheckBox Grid.Column="0"
                                  Content="Create in STG"
                                  IsChecked="{Binding CreateInStg}"/>
                        <Border Grid.Column="1" Background="#3B82F6" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right">
                            <TextBlock Text="{x:Static strings:UIStrings+Environments.Staging}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,16,*" IsEnabled="{Binding CreateInStg}">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Username" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBox Text="{Binding UserStg}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Password" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBox Text="{Binding PasswordStg}" PasswordChar="•"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- PRD Section -->
            <Border Background="{DynamicResource Layer1BackgroundBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="Auto,*">
                        <CheckBox Grid.Column="0"
                                  Content="Create in PRD"
                                  IsChecked="{Binding CreateInPrd}"/>
                        <Border Grid.Column="1" Background="#EF4444" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right">
                            <TextBlock Text="{x:Static strings:UIStrings+Environments.Production}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,16,*" IsEnabled="{Binding CreateInPrd}">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Username" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBox Text="{Binding UserPrd}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Password" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBox Text="{Binding PasswordPrd}" PasswordChar="•"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Disabled Message -->
        <Border Background="{DynamicResource Layer1BackgroundBrush}"
                CornerRadius="8"
                Padding="16"
                IsVisible="{Binding !IsEnabled}">
            <TextBlock Text="Database user creation is disabled. No PostgreSQL users will be created."
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap"/>
        </Border>
    </StackPanel>
</UserControl>
